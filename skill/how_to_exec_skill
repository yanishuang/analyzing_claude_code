### 阶段 8: Skill 执行

**文件**: `rust/crates/tools/src/lib.rs:1244-1324`

```rust
// Skill 输入结构
#[derive(Debug, Deserialize)]
struct SkillInput {
    skill: String,
    args: Option<String>,
}

// Skill 输出结构
#[derive(Debug, Serialize)]
struct SkillOutput {
    skill: String,
    path: String,
    args: Option<String>,
    description: Option<String>,
    prompt: String,
}

fn execute_skill(input: SkillInput) -> Result<SkillOutput, String> {
    // 步骤 8.1: 解析 skill 路径
    let skill_path = resolve_skill_path(&input.skill)?;

    // 步骤 8.2: 读取 SKILL.md 文件
    let prompt = std::fs::read_to_string(&skill_path)
        .map_err(|error| error.to_string())?;

    // 步骤 8.3: 提取描述
    let description = parse_skill_description(&prompt);

    // 步骤 8.4: 返回结果
    Ok(SkillOutput {
        skill: input.skill,
        path: skill_path.display().to_string(),
        args: input.args,
        description,
        prompt,
    })
}

fn resolve_skill_path(skill: &str) -> Result<PathBuf, String> {
    let requested = skill.trim().trim_start_matches('/').trim_start_matches('$');

    let mut candidates = Vec::new();
    if let Ok(codex_home) = std::env::var("CODEX_HOME") {
        candidates.push(PathBuf::from(codex_home).join("skills"));
    }

    for root in candidates {
        let direct = root.join(requested).join("SKILL.md");
        if direct.exists() {
            return Ok(direct);
        }
    }

    Err(format!("unknown skill: {requested}"))
}

fn parse_skill_description(contents: &str) -> Option<String> {
    for line in contents.lines() {
        if let Some(value) = line.strip_prefix("description:") {
            let trimmed = value.trim();
            if !trimmed.is_empty() {
                return Some(trimmed.to_string());
            }
        }
    }
    None
}
```

